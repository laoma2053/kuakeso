# ============================================
# 夸克搜 - 环境变量配置
# 复制此文件为 .env 并修改对应值
# ============================================

# ---------- 应用配置 ----------
NEXT_PUBLIC_SITE_NAME=夸克搜                    # 网站名称，显示在页面标题和头部
NEXT_PUBLIC_SITE_URL=http://localhost:6060       # 网站公开访问地址（含协议和端口），用于SEO和分享链接生成
PORT=6060                                        # Web服务监听端口，需与上面URL端口一致

# ---------- 数据库 ----------
# PostgreSQL 连接字符串，Docker部署时会由docker-compose自动注入，无需手动修改
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wangpanso?schema=public"
DB_PASSWORD=changeme123                          # 数据库密码，请务必修改为强密码

# ---------- Redis ----------
# Redis 连接地址，Docker部署时会由docker-compose自动注入
REDIS_URL="redis://localhost:6379"

# ---------- PanSou 搜索API ----------
PANSOU_API_URL="http://127.17.0.1:8888/"     # PanSou搜索服务地址，需自行部署
PANSOU_AUTH_ENABLED=false                        # 是否启用PanSou API鉴权
PANSOU_AUTH_TOKEN=""                              # PanSou API鉴权Token（启用鉴权时填写）

# ---------- 管理后台 ----------
ADMIN_TOKEN=kuakeso                              # 管理后台访问令牌，请务必修改为强密码

# ---------- 安全配置 ----------
ENCRYPTION_KEY=your-encryption-key-change-this   # 加密密钥（用于加密Cookie等敏感信息），生产环境必须修改

# ---------- 转存配置 ----------
SAVE_DIR=/来自搜索站                              # 夸克网盘中的转存目录名称
SHARE_EXPIRE_MINUTES=15                          # 资源过期清理时间（分钟），Worker按此周期扫描并删除过期资源
                                                 # 注意：这不是夸克分享链接的有效期，夸克分享固定为1天过期（兜底）
